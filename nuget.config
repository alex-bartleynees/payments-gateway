<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="github" value="https://nuget.pkg.github.com/alex-bartleynees/index.json" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>

  <!-- SharedKernel.* only ever resolves from GitHub Packages; everything else from nuget.org. -->
  <packageSourceMapping>
    <packageSource key="github">
      <package pattern="SharedKernel.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>

  <!-- Credentials are read from the GITHUB_PACKAGES_TOKEN env var at restore time (never committed).
       The token needs the read:packages scope. Set it in the nix dev shell and in CI/Docker builds. -->
  <packageSourceCredentials>
    <github>
      <add key="Username" value="alex-bartleynees" />
      <add key="ClearTextPassword" value="%GITHUB_PACKAGES_TOKEN%" />
    </github>
  </packageSourceCredentials>
</configuration>
